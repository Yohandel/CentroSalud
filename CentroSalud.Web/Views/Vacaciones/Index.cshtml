@{
    Layout = "_Layout";
}

<h2>Vacaciones</h2>

<button class="btn btn-success mb-3" onclick="abrirModal()">Nueva Vacación</button>

<table class="table table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Id</th>
            <th>Colaborador</th>
            <th>Fecha Inicio</th>
            <th>Fecha Fin</th>
            <th>Días</th>
            <th>Días Restantes</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody id="tabla"></tbody>
</table>

<div class="modal fade" id="modal">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5>Vacación</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <input type="hidden" id="id">

                <select id="tipo" class="form-select mb-2">
                    <option disabled value="">Seleccionar Tipo Colaborador</option>
                    <option value="empleado">Empleado</option>
                    <option value="medico">Médico</option>
                </select>
                <select style="display: none;" id="medico" class="form-control mb-2"></select>
                <select style="display: none;" id="empleado" class="form-control mb-2"></select>
                <input  type="date" id="inicio" class="form-control mb-2">
                <input type="date" id="fin" class="form-control">
            </div>

            <div class="modal-footer">
                <button class="btn btn-primary" onclick="guardar()">Guardar</button>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="confirmModal">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5>Posponer Vacación</h5>
            </div>

           <div class="modal-body">
            <p><strong>Colaborador:</strong> <span id="colaborador"></span></p>
            <p><strong>Fecha de Inicio:</strong> <span id="fechaInicio"></span></p>
            <p><strong>Fecha de Fin:</strong> <span id="fechaFin"></span></p>

                <input type="hidden" id="id">
                <input id="fechaCancelacion" class="form-control mb-2" type="date" placeholder="Fecha de Cancelación">
            </div>

            <div class="modal-footer">
                <button class="btn btn-danger" onclick="confirmarPosponer()">Posponer</button>
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
            </div>

        </div>
    </div>
</div>
@section Scripts {

    <script>
        let modal;
        let confirmModal;
        document.addEventListener("DOMContentLoaded", () => {

            modal = new bootstrap.Modal(document.getElementById('modal'));
            confirmModal = new bootstrap.Modal(document.getElementById('confirmModal'));

            cargar();
            cargarMedicos();
            cargarEmpleados();
        });

        async function cargar() {
            let res = await fetch("/api/vacacion/GetAll"); 
            let data = await res.json();

            let html = "";
            data.forEach(v => {
                html += `
            <tr>
                <td>${v.id}</td>
                <td>${v.nombreEmpleado || v.nombreMedico}</td>
                <td>${v.fechaInicio.split('T')[0]}</td>
                <td>${v.fechaFin.split('T')[0]}</td>
                <td>${v.diasTomados}</td>
                <td>${v.diasRestantes}</td>
                <td>
                    <button class="btn btn-warning btn-sm" onclick="editar(${v.id})">Editar</button>
                    <button class="btn btn-danger btn-sm" onclick="posponer(${v.id})">Posponer</button>
                </td>
            </tr>`;
            });

            tabla.innerHTML = html;
        }

         async function cargarMedicos() {
            let res = await fetch("/api/Medico/GetAll");
            let data = await res.json();

            let select = document.getElementById("medico");
            select.innerHTML = "";

            data.forEach(m => {
                select.innerHTML += `<option value="${m.id}">${m.nombre}</option>`;
            });
        }

        async function cargarEmpleados() {
            let res = await fetch("/api/Empleado/GetAll");
            let data = await res.json();

            let select = document.getElementById("empleado");
            select.innerHTML = "";

            data.forEach(e => {
                select.innerHTML += `<option value="${e.id}">${e.nombre}</option>`;
            });
        }

        function abrirModal() {
            id.value = "";
            empleado.value = "";
            medico.value = "";
            inicio.value = "";
            fin.value = "";
            modal.show();

            let tipoSelect = document.getElementById("tipo");
            tipoSelect.value = "";
                tipoSelect.onchange = function() {
                    if (this.value === "empleado") {
                        empleado.style.display = "block";
                        medico.style.display = "none";
                    } else if (this.value === "medico") {
                        empleado.style.display = "none";
                        medico.style.display = "block";
                    } else {
                        empleado.style.display = "none";
                        medico.style.display = "none";
                    }
                };
        }

        async function guardar() {
            let data = {
                empleadoId: empleado.value || null,
                medicoId: medico.value || null,
                fechaInicio: inicio.value.split('T')[0],
                fechaFin: fin.value.split('T')[0]
            };

            if (id.value)
                await fetch(`/api/Vacacion/Update`, { method: "PUT", headers: { "Content-Type": "application/json" }, body: JSON.stringify(data) });
            else
                await fetch(`/api/Vacacion/Create`, { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(data) });

            modal.hide();
            cargar();
        }

        function editar(id) {
            fetch(`/api/Vacacion/GetById/${id}`)
                .then(res => res.json())
                .then(v => {
                    id.value = v.id;
                    empleado.value = v.empleadoId || "";
                    medico.value = v.medicoId || "";
                    inicio.value = v.fechaInicio.split('T')[0];
                    fin.value = v.fechaFin.split('T')[0];
                    modal.show();
                    let tipoSelect = document.getElementById("tipo");
                    if (v.empleadoId) {
                        tipoSelect.value = "empleado";
                        empleado.style.display = "block";
                        medico.style.display = "none";
                    } else {
                        tipoSelect.value = "medico";
                        empleado.style.display = "none";
                        medico.style.display = "block";
                    }
                });
        }

        function posponer(idVal) {
            fetch(`/api/Vacacion/GetById/${idVal}`)
                .then(res => res.json())
                .then(v => {
                    id.value = v.id;
                    colaborador.textContent = v.nombreEmpleado || v.nombreMedico;
                    fechaInicio.textContent = v.fechaInicio.split('T')[0];
                    fechaFin.textContent = v.fechaFin.split('T')[0];
                    confirmModal.show();
                });
            confirmModal.show();
        }

        async function confirmarPosponer() {
            let data = {
                vacacionId: id.value,
                fechaCancelacion: fechaCancelacion.value + "T06:42:51.564Z"
            };
        await fetch(`/api/Vacacion/Cancel`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(data)
        });

        confirmModal.hide();
        cargar();
    }
    </script>
}