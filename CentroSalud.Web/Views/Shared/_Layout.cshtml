<!DOCTYPE html>
<html>
<head>
    <title>Centro Salud</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

<div class="d-flex">

    <!-- SIDEBAR -->
    <div class="bg-dark text-white p-3 d-flex flex-column justify-content-between" style="width:250px; min-height:100vh;">

        <!-- TOP -->
        <div>
            <h4><a class="nav-link text-white" href="/Dashboard/index">Centro Salud</a></h4>

            <ul class="nav flex-column">
                <li><a class="nav-link text-white" href="/Dashboard/index">Dashboard</a></li>
                <li><a class="nav-link text-white" href="/Empleados/index">Empleados</a></li>
                <li><a class="nav-link text-white" href="/Medicos/index">Médicos</a></li>
                <li><a class="nav-link text-white" href="/Pacientes/index">Pacientes</a></li>
                <li><a class="nav-link text-white" href="/Vacaciones/index">Vacaciones</a></li>
                <li><a class="nav-link text-white" href="/Horarios/index">Horarios</a></li>
                <li><a class="nav-link text-white" href="/Sustituciones/index">Sustituciones</a></li>
            </ul>
        </div>

        <!-- 🔥 BOTTOM (LOGOUT) -->
        <div>
            <a type="button" class="btn btn-danger w-100" href="/"">
                Cerrar Sesión
            </a>
        </div>

    </div>

    <!-- CONTENT -->
    <div class="p-4 w-100">
        @RenderBody()
    </div>

</div>


<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
    function logout() {
        
        window.location.href = "/Login/index";
    }
</script>

@RenderSection("Scripts", required: false)

</body>
</html>